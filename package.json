{
  "name": "dsp-mod-calculator",
  "version": "1.0.0",
  "description": "戴森球计划模组量化计算器 - 支持多产物配方配平、参数化增产、建筑翻倍效果",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.lib.json",
    "build:all": "npm run build && npm run build:web",
    "dev": "tsc -b tsconfig.lib.json --watch",
    "test": "jest",
    "typecheck": "tsc -b tsconfig.lib.json && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint src --ext .ts",
    "build:web": "webpack --config webpack.config.js",
    "watch:web": "webpack --config webpack.config.js --watch",
    "host": "node scripts/host-web.mjs",
    "host:web": "node scripts/host-web.mjs",
    "serve:web": "node scripts/host-web.mjs",
    "dev:web": "powershell -Command \"$watch = Start-Process cmd.exe -ArgumentList '/c','npm.cmd run watch:web' -PassThru; try { node scripts/host-web.mjs } finally { if ($watch -and !$watch.HasExited) { Stop-Process -Id $watch.Id -Force } }\""
  },
  "keywords": [
    "dyson-sphere-program",
    "calculator",
    "mod",
    "recipe",
    "optimization"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^29.5.0",
    "playwright": "^1.58.2",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.0.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yalps": "^0.6.4"
  }
}
